	measure Mes_LY_Profit_Margin =
			
			DIVIDE( [Mes_LY_Profit], [Mes_LY_Sales])
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Profit
		lineageTag: d66fd80b-b6b2-47ca-aa83-e34c78721a52

	measure 'YoY Profit Margin %' = ```
			
			    DIVIDE(
			        [Mes_Profit_Margin] - [Mes_LY_Profit_Margin], 
			        ABS([Mes_LY_Profit_Margin])
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Profit
		lineageTag: f8ac991d-6a66-453d-a873-114209642038

