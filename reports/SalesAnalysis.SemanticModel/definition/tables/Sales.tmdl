table Sales
	lineageTag: c90c54c3-ecc7-4006-acae-213e629b2b9e

	measure Mes_Profit =
			
			[Mes_Sales] - [Mes_Cost]
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Profit
		lineageTag: cb608a6f-59ce-4595-a7a2-65dad7020149

		extendedProperty MeasureTemplate =
				{
				  "version": 0,
				  "daxTemplateName": "MathematicalSubtraction"
				}

		changedProperty = FormatString

	measure Mes_Profit_Margin =
			
			DIVIDE([Mes_Profit], [Mes_Sales])
		formatString: #,0.00%;-#,0.00%;#,0.00%
		displayFolder: Profit
		lineageTag: ee424faf-c9bf-4309-a6b4-088258944206

		extendedProperty MeasureTemplate =
				{
				  "version": 0,
				  "daxTemplateName": "MathematicalDivision"
				}

		changedProperty = FormatString

	measure 'Avg Price' =
			
			AVERAGE(Sales[Unit Price])
		formatString: \$#,0.00;-\$#,0.00;\$#,0.00
		displayFolder: Pricing
		lineageTag: 06235fe0-ec6b-4480-9601-0b20fca1eaa3

		annotation PBI_FormatHint = {"currencyCulture":"en-AU"}

	measure 'Median Price' =
			
			MEDIAN(Sales[Unit Price])
		formatString: \$#,0.00;-\$#,0.00;\$#,0.00
		displayFolder: Pricing
		lineageTag: ceacc498-28dd-435f-b5b0-23a367b3a20c

		annotation PBI_FormatHint = {"currencyCulture":"en-AU"}

	measure 'Min Price' =
			
			MIN(Sales[Unit Price])
		formatString: \$#,0.00;-\$#,0.00;\$#,0.00
		displayFolder: Pricing
		lineageTag: 95899f18-b926-43ba-90d6-d0831c8cf34c

		annotation PBI_FormatHint = {"currencyCulture":"en-AU"}

	measure 'Max Price' =
			
			MAX(Sales[Unit Price])
		formatString: \$#,0.00;-\$#,0.00;\$#,0.00
		displayFolder: Pricing
		lineageTag: 10f2ab7f-ce1b-43cb-ade9-42967a141631

		annotation PBI_FormatHint = {"currencyCulture":"en-AU"}

	measure Mes_Orders =
			
			DISTINCTCOUNT(Sales[SalesOrderNumber])
		formatString: #,0
		displayFolder: Order
		lineageTag: a17bce87-617a-4ada-b8bd-86a1532c1836

	measure 'Order Lines' =
			
			COUNTROWS(Sales)
		formatString: #,0
		displayFolder: Order
		lineageTag: 8ba76031-b2f7-488d-849e-afee0cfbde36

	measure 'Sales % All Region' =
			
			DIVIDE(
				SUM(Sales[Sales]),
				CALCULATE(
					SUM(Sales[Sales]),
					REMOVEFILTERS(Region)
				)
			)
		formatString: #,0.00%;-#,0.00%;#,0.00%
		displayFolder: Ratios
		lineageTag: 1107edf8-cd88-4078-8252-d8c0b6c3fd4a

	measure 'Sales % Country' =
			
			IF(
				ISINSCOPE(Region[Region]),
				DIVIDE(
					SUM(Sales[Sales]),
					CALCULATE(
						SUM(Sales[Sales]),
						REMOVEFILTERS(Region[Region])
					)
				)
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Ratios
		lineageTag: b4db606d-64a3-43bc-b242-d48130373e12

	measure 'Sales % Group' =
			
			IF(
				ISINSCOPE(Region[Region])
					|| ISINSCOPE(Region[Country]),
				DIVIDE(
					SUM(Sales[Sales]),
					CALCULATE(
						SUM(Sales[Sales]),
						REMOVEFILTERS(
							Region[Region],
							Region[Country]
						)
					)
				)
			)
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Ratios
		lineageTag: 7f1dad48-8df8-4bf4-8316-7a6126408e1d

	measure Mes_Sales = SUM(Sales[Sales])
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Total
		lineageTag: 4b97ce1b-b93b-4eb5-a569-34c852f7b0e8

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure Mes_Cost = SUM(Sales[Cost])
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Total
		lineageTag: 773ef9df-9873-4374-956d-2dc63d431e88

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure Mes_LY_Cost = ```
			
			    CALCULATE(
			        SUM(Sales[Cost]),
			        SAMEPERIODLASTYEAR('Date'[Date])
			    )
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Total
		lineageTag: 27e78233-48f7-42ca-bfca-6af10c752d0b

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure Mes_LY_Sales = ```
			
			    CALCULATE(
			        SUM(Sales[Sales]),
			        SAMEPERIODLASTYEAR('Date'[Date])
			    )
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Total
		lineageTag: 6e656032-3932-4c57-97cf-06dc608a370b

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'YoY Sales %' = ```
			
			DIVIDE(
			    [Mes_Sales]- [Mes_LY_Sales],
			    [Mes_LY_Sales]
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Total
		lineageTag: ccdca458-4c5c-4583-85c4-b2b5909ba154

	measure 'YoY Sales Direction' = ```
			
			IF( [YoY Sales %] >= 0, "Up", "Down" )
			
			```
		displayFolder: Total
		lineageTag: caa12e3e-2d67-42cb-a7cf-3c9afdef5a99

	measure 'YoY Sales Label' =
			
			VAR pct = [YoY Sales %]
			RETURN
			IF(
			    ISBLANK(pct),
			    BLANK(),
			    IF(
			        pct >= 0,
			        "▲ " & FORMAT(pct, "0.00%") & " vs PY",
			        "▼ " & FORMAT(ABS(pct), "0.00%") & " vs PY"
			    )
			)
		displayFolder: Total
		lineageTag: bcf03ff2-a9e5-4be1-a8e5-d3120429e45e

	measure Mes_LY_Profit =
			
			[Mes_LY_Sales] - [Mes_LY_Cost]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: Profit
		lineageTag: c5e36e97-5efc-4612-807a-2e2b51857dd2

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'YoY Profit %' = ```
			
