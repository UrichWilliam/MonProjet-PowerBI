table Targets
	lineageTag: fc05aa02-32da-45a3-a497-78e97999d244

	measure Target =
			
			IF(
				HASONEVALUE('Salesperson (Performance)'[Salesperson]),
				SUM(Targets[TargetAmount])
			)
		formatString: \$#,0;-\$#,0;\$#,0
		lineageTag: 91afbca0-b836-4e6e-b565-be9ff9dce92f

		annotation PBI_FormatHint = {"currencyCulture":"en-AU"}

	measure Variance =
			
			IF(
				HASONEVALUE('Salesperson (Performance)'[Salesperson]),
				SUM(Sales[Sales]) - [Target]
			)
		formatString: \$#,0;-\$#,0;\$#,0
		lineageTag: e6d05981-0f46-48d0-9e79-a63485d3f00c

		annotation PBI_FormatHint = {"currencyCulture":"en-AU"}

	measure 'Variance Margin' =
			
			DIVIDE([Variance], [Target])
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 0a85a582-ae44-4cf0-8b5a-67500d460a24

	column EmployeeID
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: 7552db63-13e7-4c1c-8e70-ee51dcd1066d
		summarizeBy: none
		sourceColumn: EmployeeID

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column TargetAmount
		dataType: decimal
		isHidden
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: c8642aff-9cd7-43b3-ad05-ba32d7661db3
		summarizeBy: sum
		sourceColumn: TargetAmount

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	column TargetMonth
		dataType: dateTime
		isHidden
		formatString: Long Date
		lineageTag: 68de4399-a6d7-4f91-9bbb-c07d085ca6c1
		summarizeBy: none
		sourceColumn: TargetMonth

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

