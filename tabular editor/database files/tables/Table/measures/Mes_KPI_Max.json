{
  "name": "Mes_KPI_Max",
  "expression": [
    "",
    "    CALCULATE(",
    "        MAXX(",
    "            ALL('Product'[Category]), ",
    "            --[Mes_Sales]",
    "            --'KPI Selector'[Selected KPI Value]",
    "            --SELECTEDMEASURE()",
    "            SWITCH(",
    "                [Selected KPI Number],",
    "                0, [Mes_Sales],",
    "                1, [Mes_Profit],",
    "                2, [Mes_Profit_Margin],",
    "                3, [Mes_Orders]",
    "            )",
    "        )",
    "    )"
  ],
  "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
