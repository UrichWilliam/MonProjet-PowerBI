{
  "name": "YoY Profit Margin Label",
  "expression": [
    "",
    "VAR pct = [YoY Profit Margin %]",
    "RETURN",
    "IF(",
    "    ISBLANK(pct),",
    "    BLANK(),",
    "    IF(",
    "        pct >= 0,",
    "        \"▲ \" & FORMAT(pct, \"0.00%\") & \" vs PY\",",
    "        \"▼ \" & FORMAT(ABS(pct), \"0.00%\") & \" vs PY\"",
    "    )",
    ")"
  ],
  "displayFolder": "Profit",
