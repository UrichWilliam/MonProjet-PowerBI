{
  "name": "YoY Sales Label",
  "expression": [
    "",
    "VAR pct = [YoY Sales %]",
    "RETURN",
    "IF(",
    "    ISBLANK(pct),",
    "    BLANK(),",
    "    IF(",
    "        pct >= 0,",
    "        \"▲ \" & FORMAT(pct, \"0.00%\") & \" vs PY\",",
    "        \"▼ \" & FORMAT(ABS(pct), \"0.00%\") & \" vs PY\"",
    "    )",
    ")"
  ],
  "displayFolder": "Total",
  "lineageTag": "bcf03ff2-a9e5-4be1-a8e5-d3120429e45e"
}