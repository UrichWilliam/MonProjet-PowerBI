{
  "name": "YoY Profit Label",
  "expression": [
    "",
    "VAR pct = [YoY Profit %]",
    "RETURN",
    "IF(",
    "    ISBLANK(pct),",
    "    BLANK(),",
    "    IF(",
    "        pct >= 0,",
    "        \"▲ \" & FORMAT(pct, \"0.00%\") & \" vs PY\",",
    "        \"▼ \" & FORMAT(ABS(pct), \"0.00%\") & \" vs PY\"",
    "    )",
    ")"
  ],
  "displayFolder": "Profit",
  "lineageTag": "ce421921-2c30-49f8-9d7f-ecd205786138"
}