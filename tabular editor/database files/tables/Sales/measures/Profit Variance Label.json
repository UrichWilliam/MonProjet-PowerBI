{
  "name": "Profit Variance Label",
  "expression": [
    "",
    "VAR pv = [Profit Variance]",
    "RETURN",
    "IF(",
    "    ISBLANK(pv),",
    "    BLANK(),",
    "    IF(",
    "        pv >= 0,",
    "        \"▲ \" & FORMAT(pv/1000000, \"0.00$\") & \" vs PY\",",
    "        \"▼ \" & FORMAT(ABS(pv)/1000000, \"0.00$\") & \" vs PY\"",
    "    )",
    ")"
  ],
